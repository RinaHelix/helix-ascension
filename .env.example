# Helix Ascension — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/helix_ascension

# Alpaca (Paper Trading ONLY — see CRITICAL.md Rule 9)
ALPACA_KEY=your_paper_trading_key
ALPACA_SECRET=your_paper_trading_secret
ALPACA_PAPER=true

# AI (Rina — when ready)
ANTHROPIC_API_KEY=your_key_here

# Governor
GOVERNOR_DRY_RUN=true
GOVERNOR_KILL_SWITCH=false
GOVERNOR_LOG_LEVEL=verbose
